# ─────────────────────────────────────────────
#  Generative AI Chatbot — Environment Config
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values

# Google Gemini API Key (required)
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Model to use (optional, defaults to gemini-1.5-flash)
GEMINI_MODEL=gemini-1.5-flash

# Sliding window — max number of message turns to keep in context (optional)
# Each "turn" = 1 user message + 1 model response
MAX_HISTORY_TURNS=10

# ─────────────────────────────────────────────
# PostgreSQL Persistence (Phase 5 — optional)
# ─────────────────────────────────────────────
# Only needed if you want persistent chat sessions across restarts
# Leave blank to use in-memory mode (default)

DB_HOST=localhost
DB_PORT=5432
DB_NAME=chatbot_db
DB_USER=postgres
DB_PASSWORD=your_db_password_here
